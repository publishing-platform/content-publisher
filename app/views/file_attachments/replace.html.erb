<% content_for :title, t("file_attachments.replace.title", title: @edition.title_or_fallback) %>

<% back_link_path = if params[:wizard] == "featured-attachment-replace"
                      featured_attachments_path(@edition.document)
                    elsif params[:wizard] == "featured-attachment-upload"
                      featured_attachments_path(@edition.document)
                    else
                      file_attachments_path(@edition.document)
                    end %>

<% content_for :back_link, render_back_link(href: back_link_path,
                                            data_attributes: { "modal-action": "back" }) %>

<div class="row">
  <div class="<%= rendering_context == 'modal' ? 'col-xs-12' : 'col-xs-12 col-md-8' %>">
    <%= form_tag(
      replace_file_attachment_path(@edition.document, @attachment.file_attachment_id),
      method: :patch,
      multipart: true,
      data: {
        "modal-action": "update"
      },
    ) do %>
      <%= hidden_field_tag(:wizard, params[:wizard]) %>

      <% has_error = @issues&.has_key?(:file_attachment_title) %>

      <%= label_tag "title", t("file_attachments.replace.attachment_title.heading"), class: "form-label fw-bold" %>
      <%= text_field_tag "file_attachment[title]",
            params.dig(:file_attachment, :title) || @attachment.title,
            id: "title",
            aria: { describedby: has_error ? "file_attachment_title-errors" : nil },
            class: "form-control mb-3 #{(has_error ? "is-invalid" : nil)}" %>
      
      <%= render "components/errors", {
        field: :file_attachment_title,
        classes: "mb-3"
      } %>   

      <%= label_tag :file, t("file_attachments.replace.attachment_file.heading"), class: "form-label fw-bold" %>

      <div class="text-muted">
        <%= render_markdown(t("file_attachments.replace.attachment_file.description_markdown")) %>
      </div>      

      <%= render "publishing_platform_publishing_components/components/inset_text", {
        text: render_markdown(
          t("file_attachments.replace.attachment_file.filename_change_callout_markdown",
            filename: @attachment.filename)
        ),
      } %>      
      
      <div class="mb-3">        
        <%= file_field_tag "file_attachment[file]", id: "file", class: "form-control" %>
      </div>         
      
      <% 
        button_text = if params[:wizard] == "featured-attachment-upload"
                        "Save and continue"
                      else
                        "Save"
                      end
      %>

      <%= submit_tag button_text, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>