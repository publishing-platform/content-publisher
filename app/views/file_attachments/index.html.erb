<% content_for :title, t("file_attachments.index.title", title: @edition.title_or_fallback) %>

<div class="row">
  <div class="<%= rendering_context == 'modal' ? 'col-xs-12' : 'col-xs-12 col-md-8' %>">
    <div class="app-pane">
      <%= form_tag(
        file_attachments_path(@edition.document),
        multipart: true,
        data: { "modal-action": "upload" }
      ) do %>      
        <h2 class="h4">
          <%= label_tag :file, t("file_attachments.index.upload.title") %>
        </h2>  
        
        <div id="file-hint" class="text-muted mb-3"><%= render_markdown(t("file_attachments.index.upload.description_markdown")) %></div>

        <div class="mb-3">        
          <%= file_field_tag :file, class: "form-control", aria: { describedby: "file-hint" } %>
        </div>  

        <% has_error = @issues&.has_key?(:file_attachment_title) %>

        <%= label_tag "title", t("file_attachments.index.attachment_title.heading"), class: "form-label fw-bold" %>
        <%= text_field_tag "title",
              params[:title],
              id: "title",
              aria: { describedby: has_error ? "file_attachment_title-errors" : nil },
              class: "form-control mb-3 #{(has_error ? "is-invalid" : nil)}" %>
        
        <%= render "components/errors", {
          field: :file_attachment_title,
          classes: "mb-3"
        } %>          
        
        <%= submit_tag "Upload", class: "btn btn-primary" %>        
      <% end %>
    </div>

    <% attachments = @edition.file_attachment_revisions %>

    <% if attachments.any? %>
      <h2 class="h4">
        <%= t("file_attachments.index.other_attachments") %>
      </h2>

      <% attachments.each do |attachment| %>
        <%= render "file_attachment", edition: @edition, attachment: attachment %>
      <% end %>
    <% end %>
  </div>
</div>