<%
  title ||= nil
  edit ||= {}
  delete ||= {}
  items ||= []
  block ||= yield

  heading_level = [*1..6].include?(heading_level) ? "h#{heading_level}" : "h3"
  attributes = {}
  attributes[:class] = "app-c-summary-list"
  attributes[:id] = id if local_assigns.include?(:id)

%>
<% if title || items.any? %>
  <%= tag.div **attributes do %>
    <% if title %>

      <%= content_tag(heading_level, title, class: "h4 app-c-summary-list__group-title") %>

      <% if edit.any? %>
        <% edit_main_link = capture do %>
          <%
            edit_section_link_text = edit[:link_text] || "Change"
          %>
          <%= link_to edit.fetch(:href) do %>
            <%= edit_section_link_text %><%= tag.span " #{title}", class: "visually-hidden" unless edit[:link_text_no_enhance] -%>
          <% end %>
        <% end %>
      <% end %>

      <% if delete.any? %>
        <% delete_main_link = capture do %>
          <% delete_section_link_text = delete[:link_text] || "Delete" %>
          <%= link_to delete.fetch(:href),
                class: "link-danger" do %>
            <%= delete_section_link_text %><%= tag.span " #{title}", class: "visually-hidden" unless delete[:link_text_no_enhance] -%>
          <% end %>
        <% end %>
      <% end %>

      <% if edit_main_link && delete_main_link %>
        <%= tag.ul class: "app-c-summary-list__actions-list app-c-summary-list__group-actions-list" do %>
          <%- if edit.any? %>
            <%= tag.li class: "app-c-summary-list__actions-list-item" do -%>
              <%= edit_main_link %>
            <% end %>
          <% end %>
          <% if delete.any? %>
            <%= tag.li class: "app-c-summary-list__actions-list-item" do -%>
              <%= delete_main_link %>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <%= tag.div class: "app-c-summary-list__group-actions-list" do %>
          <%= edit_main_link %>
          <%= delete_main_link %>
        <% end %>
      <% end %>
    <% end %>

    <% any_body_actions = items.detect { |item| item.has_key?("edit") || item.has_key?("delete") } %>
    <% if items.any? %>
      <%= tag.dl class: "app-c-summary-list__items" do %>
        <% items.each do |item| %>
          <%
            item_body_actions = (item.fetch(:edit, {}).any? || item.fetch(:delete, {}).any?)

            if any_body_actions.present? && item_body_actions.blank?
              classes = "app-c-summary-list__row app-c-summary-list__row--no-actions"
            else
              classes = "app-c-summary-list__row"
            end
          %>
          <%= tag.div class: classes do %>

            <%= tag.dt item[:field], class: "app-c-summary-list__key" %>
            <%= tag.dd item[:value], class: "app-c-summary-list__value" %>

            <% if item.fetch(:edit, {}).any? %>
              <% edit_link = capture do %>
                <% edit_link_text = item[:edit][:link_text] || "Change" %>
                <%= link_to item[:edit].fetch(:href) do %>
                  <%= edit_link_text %>
                  <%= tag.span " #{item[:field]}", class: "visually-hidden" unless item[:edit][:link_text_no_enhance] -%>
                <% end %>
              <% end %>
            <% end %>

            <% if item.fetch(:delete, {}).any? %>
              <% delete_link = capture do %>
                <% delete_link_text = item[:delete][:link_text] || "Delete" %>
                <%= link_to item[:delete].fetch(:href),
                      class: "link-danger" do %>
                  <%= delete_link_text %>
                  <%= tag.span " #{item[:field]}", class: "visually-hidden" unless item[:delete][:link_text_no_enhance] -%>
                <% end %>
              <% end %>
            <% end %>

            <% if edit_link && delete_link %>
              <%= tag.dd class: "app-c-summary-list__actions" do %>
                <%= tag.ul class: "app-c-summary-list__actions-list" do %>
                  <% if edit_link %>
                    <%= tag.li class: "app-c-summary-list__actions-list-item" do %>
                      <%= edit_link %>
                    <% end %>
                  <% end %>
                  <% if delete_link %>
                    <%= tag.li class: "app-c-summary-list__actions-list-item" do %>
                      <%= delete_link %>
                    <% end %>
                  <% end %>
                <% end %>
              <% end %>
            <% elsif edit_link || delete_link %>
              <%= tag.dd class: "app-c-summary-list__actions" do %>
                <%= edit_link %>
                <%= delete_link %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%= tag.div block, class: "gem-c-summary__block" if block %>
  <% end %>
<% end %>